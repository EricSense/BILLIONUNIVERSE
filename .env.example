# Billion Universe — copy to .env.local and fill in
# https://github.com/your-org/billion-universe

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin (used to protect /admin endpoints — set a long random string)
# BU_ADMIN_TOKEN=

# Supabase (server-side only)
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Auth (add when you integrate Clerk, NextAuth, etc.)
# AUTH_SECRET=
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=

# AI / LLM (for signal synthesis and scenario engine)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Data / APIs (for signal feeds — macro, supply chain, etc.)
# DATA_API_KEY_1=
# DATA_API_KEY_2=
